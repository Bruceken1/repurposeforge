{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "services": {
    "web": {
      "rootDir": "apps/web",
      "buildCommand": "npm run build",
      "startCommand": "npm run preview"
    },
    "api": {
      "rootDir": "apps/api",
      "startCommand": "npm start"
    }
  }
}